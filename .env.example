# MINXG Environment Variables — Template
#
# Copy this file to `.env` and fill in real values. The `.env` file is
# git-ignored. NEVER commit real keys.

# ─── LLM Provider Keys (only fill in the ones you actually use) ──────────────
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_API_KEY=your-google-key-here

# ─── Service Endpoints ───────────────────────────────────────────────────────
MINXG_GATEWAY_HOST=127.0.0.1
MINXG_GATEWAY_PORT=8765
MINXG_LOG_LEVEL=INFO

# ─── Persistence / Storage ──────────────────────────────────────────────────
MINXG_DATA_DIR=./data
MINXG_CACHE_DIR=./.cache
