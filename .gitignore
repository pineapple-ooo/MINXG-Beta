# ASan reproducibility harness — keep both source and pre-built .so in VCS
# so an auditor can rerun the leak check without a fresh toolchain.
!tests/asan_harness.c
!build_asan/libminxg_asan.so

# Stray C test harnesses at the repo root that aren't wired into the
# reproducible ASan run — they were rebuilt for local experimentation.
/bmh_test.c
/mini_test.c
/simple_test.c

# C/C++ build subdirs (in case `build/` is moved)
cmake-build-*/
CMakeFiles/
CMakeCache.txt
CMakeUserPresets.json
compile_commands.json

# cmake build output (one per cmake target dir)
**/build/

